# Vorlage für die Laufzeit-Umgebungsvariablen. Echte Werte in .env (nicht committen).

DATABASE_URL="postgresql://marketplace:marketplace@localhost:5432/marketplace?schema=public"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="dev-secret-change-me-in-production-please"
ANTHROPIC_API_KEY=

# Stripe — Kreditkarten-Zahlung der Jahres-/Zugangsgebühr.
# TEST-Keys: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
# Webhook-Signing-Secret aus dem Stripe-Dashboard (oder `stripe listen`): whsec_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Jahres-Zugangsgebühr in Euro (ganzzahlig)
MEMBERSHIP_PRICE_EUR=290

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  RESELLER
  OEM
  ENDKUNDE
  ADMIN
}

enum UserTrustTier {
  UNVERIFIED
  VERIFIED
  TRADE_ASSURED
  PREMIUM
  DIAMOND
}

enum ListingStatus {
  ACTIVE
  PAUSED
  SOLD
  ARCHIVED
}

enum RfqStatus {
  OPEN
  ACCEPTED
  EXPIRED
  CANCELED
}

enum RfqVisibility {
  PUBLIC
  VERIFIED_ONLY
}

enum RfqOfferStatus {
  PENDING
  ACCEPTED
  DECLINED
  WITHDRAWN
}

enum TransactionStatus {
  PENDING
  SHIPPED
  COMPLETED
  CANCELED
  DISPUTED
}

enum ReviewTag {
  FAST_RESPONSE
  QUALITY_AS_DESCRIBED
  ON_TIME_DELIVERY
  FAIR_NEGOTIATION
}

enum ChemistryBase {
  MINERAL
  SYNTHETIC
  SEMI_SYNTHETIC
  ESTER
  PAG
  OTHER
}

enum ProductionType {
  CONTRACT_MANUFACTURING   // Lohnfertigung — wechselnde Werkstoffe/Aufträge
  SERIAL_PRODUCTION        // Serienproduktion — konstantes Werkstück/Verfahren
  MIXED                    // Mischbetrieb
}

enum CoolantConcentrateForm {
  CONVENTIONAL_EMULSION    // klassische milchige Emulsion (Mineralöl + Tenside)
  SEMI_SYNTHETIC           // halbsynthetisch (milchig-opal)
  FULL_SYNTHETIC           // vollsynthetisch (klar, ohne Mineralöl)
  TWO_COMPONENT            // Zweikomponenten-System
}

enum PackagingForm {
  DRUM
  IBC
  TANK
  CANISTER
  BULK
  OTHER
}

enum SdsCategory {
  WATER_MISCIBLE_COOLANT
  NEAT_CUTTING_OIL
  GRINDING_OIL
  HYDRAULIC_OIL
  GEAR_OIL
  MOTOR_OIL
  GREASE
  OTHER
}

enum SdsLanguage {
  DE
  EN
  FR
  IT
  OTHER
}

enum ProductCategory {
  COOLANT_WATER_MIX     // wassermischbarer KSS-Konzentrat
  COOLANT_NEAT          // nicht wassermischbares Schneidöl
  GRINDING_OIL          // Schleiföl
  EDM_FLUID             // Erodieröl (Senk/Draht), Dielektrikum
  HYDRAULIC_OIL
  GEAR_OIL
  COMPRESSOR_OIL
  SLIDEWAY_OIL          // Bettbahnöl
  FORMING_OIL           // Stanz-/Umform-/Tiefziehöl
  CLEANER               // Reiniger / Entfetter
  CORROSION_PROTECTION
  GREASE
  SPECIALTY             // Spezial-/Sonderschmierstoff
  ADDITIVE
  OTHER
}

enum MaterialCompatibility {
  RECOMMENDED   // explizit für diesen Werkstoff empfohlen
  COMPATIBLE    // unproblematisch
  CAUTION       // mit Einschränkungen / Bedingungen
  UNSUITABLE    // nicht geeignet, dokumentierte Probleme
}

enum BusinessFocus {
  COOLANT              // Kühlschmierstoffe (wassermischbar)
  NEAT_OIL             // Nicht wassermischbare Schneidöle
  LUBRICANT            // Schmierstoffe allgemein (Hydraulik, Getriebe, Motor)
  GREASE               // Schmierfette
  CLEANER              // Reiniger / Entfetter
  CORROSION_PROTECTION // Korrosionsschutz
  CHEMICAL_SUPPLIER    // Chemie-Distributor / Mineralöl-Handel
  ADDITIVE             // Additiv-Hersteller
}

model Manufacturer {
  id        String   @id @default(cuid())
  name      String   @unique   // Display name, z.B. "Blaser Swisslube"
  slug      String   @unique   // url-safe, z.B. "blaser-swisslube"

  logoPath  String?            // /brand-logos/BlaserSwisslubeLogo.png
  website   String?            // https://www.blaser.com

  headquartersCountry String?  // ISO-3166-1 alpha-2 oder Klartext
  headquartersCity    String?
  foundedYear         Int?

  businessFocus   BusinessFocus[] @default([])
  productFamilies String[]        @default([])  // z.B. ["Blasocut", "Vasco", "Synergy"]
  description     String?

  // Wissens-Metadaten — was wir aus dem Web/Datenblättern wissen
  knownForApplications String[] @default([])    // z.B. ["Schleifen", "Drehen Alu", "Tiefbohren"]
  notes               String?                    // freitext, manuell pflegbar

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listings  Listing[]
  sds       SafetyDataSheet[]
  products  Product[]

  @@index([slug])
}

model Product {
  id              String       @id @default(cuid())
  manufacturerId  String
  manufacturer    Manufacturer @relation(fields: [manufacturerId], references: [id], onDelete: Cascade)

  name            String       // Vollständiger Name z.B. "Blasocut 2000 CF"
  slug            String       // url-safe, eindeutig pro Hersteller
  productFamily   String?      // z.B. "Blasocut"
  category        ProductCategory
  chemistry       ChemistryBase?

  description     String?

  // Anwendung
  applicationAreas    String[] @default([])  // Drehen, Fräsen, Schleifen, Stanzen, ...
  suitableMaterials   String[] @default([])  // Stahl, Alu, Buntmetall, Guss, Titan, Hartmetall
  unsuitableMaterials String[] @default([])  // Werkstoffe wo Probleme dokumentiert sind

  // Eignung für Produktionsart (Lohnfertigung vs Serie)
  productionType      ProductionType?

  // Form bei wassermischbaren KSS — entscheidend für Auswahl (milchig vs klar)
  concentrateForm     CoolantConcentrateForm?

  // Praxis-Probleme die mit diesem Produkt explizit adressiert (oder bekannt) sind
  // Werte: "Fleckenbildung Buntmetall", "Schaum", "Geruch", "Hautirritation",
  //   "harzartige Ablagerungen", "kurze Standzeit", "schlechte Filtrierbarkeit",
  //   "Alu-Verfärbung", "Spritzwasserbeständigkeit", "Kompatibilität mit anderen
  //   Hochdruck-MMS", "Werkzeugstandzeit", "Tramp-Oil-Aufnahme"
  criticalIssuesAddressed String[] @default([])
  criticalIssuesKnown     String[] @default([])  // dokumentierte Schwachpunkte

  // Refraktometer — Schlüsselwert für KSS-Konzentratbestimmung
  refractometerFactor Float?    // Brix × Faktor = % Konzentration

  // Empfohlene Konzentration im Gebrauchsbereich (wassermischbare KSS)
  recommendedConcentrationMin Float?  // % v/v
  recommendedConcentrationMax Float?  // % v/v

  // pH
  phConcentrate Float?
  phEmulsionMin Float?           // bei Soll-Konzentration
  phEmulsionMax Float?

  // Physik
  densityGcm3   Float?           // bei 20 °C
  flashpointC   Int?              // °C (nur für Öle)
  viscosityIso  String?           // ISO VG (für Öle)
  viscosityKv40 Float?            // mm²/s bei 40 °C
  viscosityKv100 Float?           // mm²/s bei 100 °C

  // Ansetzwasser-Anforderungen (wassermischbare KSS)
  waterHardnessMinDh  Int?       // °dH min empfohlen
  waterHardnessMaxDh  Int?       // °dH max empfohlen
  waterHardnessNotes  String?    // z.B. "demineralisiertes Wasser ungeeignet"

  // Lebensmittel-/Norm-Freigaben
  certifications  String[]  @default([])  // FDA H1, DIN 51385, TRGS 611, OEM-Freigaben

  // Markierungen
  containsBor              Boolean?
  containsFormaldehydeDepot Boolean?
  containsMineralOil       Boolean?
  containsChlorine         Boolean?
  mineralOilContentPct     Float?       // 0-100 %

  // Quellen
  sourceUrl       String?       // Produktseite Hersteller
  dataSheetUrl    String?       // technisches Datenblatt (PDS)
  sdsUrl          String?       // Sicherheitsdatenblatt
  sourceConfidence String?      // "verifiziert", "modelliert", "geschätzt"

  notes           String?

  // Verlinktes SDS aus der eigenen SDS-Bibliothek (sofern Match per Hersteller+Name möglich war)
  safetyDataSheetId String?
  safetyDataSheet   SafetyDataSheet? @relation(fields: [safetyDataSheetId], references: [id], onDelete: SetNull)

  // Normalisierter Suchindex: name + manufacturer + productFamily, lowercase,
  // ohne Trennzeichen — erlaubt "bcool755" → "B-Cool 755", "hocut795mp" → "Hocut 795 MP".
  searchTokens     String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  compatibilityNotes MaterialCompatibilityNote[]
  priceObservations  PriceObservation[]
  issues             ProductIssue[]

  @@unique([manufacturerId, slug])
  @@index([manufacturerId])
  @@index([category])
  @@index([productFamily])
  @@index([safetyDataSheetId])
  @@index([searchTokens])
}

model ComparisonAnalysis {
  id           String   @id @default(cuid())
  // sha256 über die sortierte Liste der verglichenen IDs (Listings oder Products)
  cacheKey     String   @unique
  scope        String   // "listings" oder "products"
  ids          String[] // die verglichenen IDs (sortiert wie cacheKey berechnet)
  // Strukturiertes Ergebnis als JSON: { perItem: [...], recommendation: "...", model: "..." }
  result       Json
  source       String   // "anthropic-claude" | "heuristic-fallback"
  createdAt    DateTime @default(now())

  @@index([scope, createdAt])
}

model MaterialCompatibilityNote {
  id          String                @id @default(cuid())
  productId   String?
  product     Product?              @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Bei productId = null: allgemeine Regel (z.B. "Buntmetall + pH > 9.5 → Verfärbung")
  // Bei productId gesetzt: produkt-spezifischer Hinweis
  scope       String                // "product" oder "general"

  material    String                // "Aluminium", "Buntmetall", "Magnesium", "Grauguss", "Titan", "Stahl", "Edelstahl"
  compatibility MaterialCompatibility

  condition   String?               // z.B. "pH > 9.5", "Konzentration > 8%", "demineralisiertes Wasser"
  note        String                // Erklärung was passiert / worauf zu achten

  sourceUrl   String?               // Hersteller-Doku, Fachartikel, FAQ
  sourceLabel String?               // z.B. "Blaser FAQ", "VSI-Merkblatt"

  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([productId])
  @@index([material])
}

// ============================================================
// Material-/Inhaltsstoff-Verträglichkeit (Dichtungen, Kunststoffe)
// ============================================================

enum MaterialCategory {
  ELASTOMER      // NBR, EPDM, FKM, Silikon, HNBR, FFKM, PUR, ...
  THERMOPLASTIC  // PA, POM, PP, PE, PVC, PTFE, PEEK
  THERMOSET      // Epoxidharz, Phenolharz
  METAL          // Stahl, Alu, Cu, Mg, ...
  COATING        // Lacke, Beschichtungen
}

enum IngredientCategory {
  AMINE                 // Mono/Di/Triethanolamin, Morpholin, DEA
  BIOCIDE               // Isothiazolinone, Bronopol, Triazin, Pyrithion, OIT
  FORMALDEHYDE_RELEASER // Bronopol, DMDM-Hydantoin, Triazin (Untergruppe Biozide)
  BASE_OIL_MINERAL      // Mineralöl (Naphthenisch, Paraffinisch)
  BASE_OIL_ESTER        // Ester-Basisöl
  BASE_OIL_PAO          // Polyalphaolefin
  BASE_OIL_PAG          // Polyalkylenglykol
  EMULSIFIER            // Tenside (anionisch, nichtionisch)
  EP_ADDITIVE_S         // Schwefel-EP
  EP_ADDITIVE_P         // Phosphor-EP (ZDDP, ZnDTP)
  EP_ADDITIVE_CL        // Chlorparaffine (SCCP, MCCP)
  CORROSION_INHIBITOR   // Carboxylate, MBT, BTA, Aminborate
  BORATE                // Borsäure, Borax, Perborate
  CHELATE               // EDTA, NTA
  GLYCOL_ETHER          // Butylglykol, Methoxypropanol
  SOLVENT_AROMATIC      // Toluol, Xylol, Naphtha
  SOLVENT_POLAR         // Ketone, Aceton, Alkohole
  WATER                 // Träger / Hauptphase wassermischbarer KSS
  ACID                  // Carbonsäuren, Borsäure, Phosphorsäure
  ALKALI                // KOH, NaOH, Carbonate
  OTHER
}

enum EffectType {
  SWELLING       // Volumen-/Längenzunahme
  SHRINKAGE      // Schwund (Weichmacher-/Additiv-Extraktion)
  HARDENING      // Verhärtung
  EMBRITTLEMENT  // Versprödung, Rissbildung
  EXTRACTION     // Auswaschen von Mischungsbestandteilen
  ATTACK_NETWORK // Angriff der Vernetzungsbrücken (irreversibel)
  NONE
}

model Material {
  id              String           @id @default(cuid())
  slug            String           @unique     // "nbr", "epdm", "fkm-bisphenol"
  name            String                       // "NBR (Nitril-Butadien-Kautschuk)"
  shortName       String                       // "NBR"
  category        MaterialCategory

  description     String?
  typicalUseCases String[]         @default([])  // ["Hydraulik-O-Ringe", "Wellendichtringe"]
  temperatureMinC Int?
  temperatureMaxC Int?

  // Charakteristik nach Polarität (similia similibus solvuntur)
  isPolar         Boolean?

  // Wenn Untertyp: Verweis auf "Eltern"-Familie (FKM-Bisphenol → FKM)
  parentSlug      String?

  sourceUrl       String?
  sourceLabel     String?
  notes           String?

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  compatibilities IngredientMaterialCompatibility[]

  @@index([category])
  @@index([slug])
}

model Ingredient {
  id           String              @id @default(cuid())
  slug         String              @unique    // "monoethanolamine", "boric-acid"
  name         String                          // "Monoethanolamin (MEA)"
  shortName    String?                         // "MEA"
  category     IngredientCategory
  casNumbers   String[]            @default([])

  functionInFluid          String? // "pH-Stabilisierung & Korrosionsschutz für Eisen"
  typicalConcentrationPct  Float?  // typischer Anteil in KSS-Konzentrat in %
  isSvhc                   Boolean @default(false)
  description              String?

  sourceUrl   String?
  sourceLabel String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  compatibilities IngredientMaterialCompatibility[]

  @@index([category])
}

model IngredientMaterialCompatibility {
  id           String   @id @default(cuid())
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  materialId   String
  material     Material   @relation(fields: [materialId], references: [id], onDelete: Cascade)

  rating       MaterialCompatibility   // RECOMMENDED, COMPATIBLE, CAUTION, UNSUITABLE
  effectType   EffectType?
  swellPctMin  Float?                   // erwartete Volumenquellung in %
  swellPctMax  Float?

  conditionNote String?                 // "bei T > 60°C", "Langzeit > 1000h", "dynamisch"
  note          String                  // Erklärung des Mechanismus / praktische Wirkung

  sourceUrl    String?
  sourceLabel  String?                  // "ISM Compatibility Chart", "Trelleborg DB"
  confidence   String?                  // "verifiziert", "indikativ", "geschätzt"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ingredientId, materialId])
  @@index([materialId])
  @@index([ingredientId])
  @@index([rating])
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String
  pseudonym    String        @unique
  role         UserRole      @default(RESELLER)
  trustTier    UserTrustTier @default(UNVERIFIED)
  // INTERN / NUR SUPERADMIN — bezahlter Sichtbarkeits-Boost.
  // Höherer Wert ⇒ Angebote dieses Resellers erscheinen weiter oben in
  // Suchergebnissen und Vorschlägen. Wird NIE an die normale UI/API
  // ausgegeben und ist nur über /admin durch den Eigentümer steuerbar.
  searchBoost  Int           @default(0)
  // Bezahlte Jahres-/Zugangsmitgliedschaft (Stripe). Aktiv, solange
  // membershipValidUntil in der Zukunft liegt.
  stripeCustomerId    String?
  membershipValidUntil DateTime?
  payments            Payment[]
  // KYC light — internal only
  companyName  String?
  vatId        String?
  country      String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  listings        Listing[]
  buyerThreads    Conversation[] @relation("BuyerThreads")
  sellerThreads   Conversation[] @relation("SellerThreads")
  messages        Message[]
  rfqs            Rfq[]
  offers          RfqOffer[]
  buyerTxns       Transaction[] @relation("BuyerTx")
  sellerTxns      Transaction[] @relation("SellerTx")
  reviewsGiven    Review[]      @relation("ReviewsGiven")
  reviewsReceived Review[]      @relation("ReviewsReceived")
  submittedPrices PriceObservation[] @relation("SubmittedPrices")
  verifiedPrices  PriceObservation[] @relation("VerifiedPrices")

  submittedIssues ProductIssue[]     @relation("ProductIssueSubmitted")
  verifiedIssues  ProductIssue[]     @relation("ProductIssueVerified")

  passwordResetTokens PasswordResetToken[]
}

// ============================================================
// Zahlungen (Stripe) — aktuell: Jahres-/Zugangsgebühr (Mitgliedschaft).
// ============================================================
enum PaymentKind {
  MEMBERSHIP // Jahres-/Zugangsgebühr
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

model Payment {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  kind      PaymentKind   @default(MEMBERSHIP)
  status    PaymentStatus @default(PENDING)
  amountEur Float
  currency  String        @default("eur")

  // Stripe-Referenzen (Checkout-Session / PaymentIntent)
  stripeSessionId       String? @unique
  stripePaymentIntentId String?

  // Abgedeckter Zeitraum (bei MEMBERSHIP: 1 Jahr ab Zahlung)
  periodStart DateTime?
  periodEnd   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

// ============================================================
// Passwort-Reset — "Passwort vergessen"-Flow
// ============================================================
//
// State of the art: Der eigentliche Token wird dem Nutzer per Link
// zugestellt; in der DB liegt nur sein sha256-Hash. Tokens laufen nach
// kurzer Zeit ab und sind genau einmal verwendbar (usedAt).
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// ============================================================
// Preisbeobachtungen — historische Marktpreise
// ============================================================
//
// Quellen:
//   - USER_SUBMITTED:  User meldet beobachteten Preis → PENDING bis verifiziert
//   - TRANSACTION:     automatisch aus abgeschlossener Marketplace-Transaktion → direkt VERIFIED
//   - LIST_PRICE:      Hersteller-Listenpreis (selten verfügbar)
//   - DISTRIBUTOR_QUOTE: Distributor-Webshop-Preis
//   - SEED_INDICATIVE: initial-Seed-Beispieldaten (markiert!)
//
// Aggregation: lib/price-aggregation.ts berechnet monatlichen Median für Charts.

enum PriceSource {
  USER_SUBMITTED
  TRANSACTION
  LIST_PRICE
  DISTRIBUTOR_QUOTE
  AGGREGATED
  SEED_INDICATIVE
}

enum PriceStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum PriceUnit {
  EUR_PER_L
  EUR_PER_KG
  EUR_PER_PIECE
  CHF_PER_L
  CHF_PER_KG
  USD_PER_L
  USD_PER_KG
}

model PriceObservation {
  id            String      @id @default(cuid())
  productId     String
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  observedAt    DateTime    // Datum des Preises (kann historisch sein)
  pricePerUnit  Float
  unit          PriceUnit   @default(EUR_PER_L)

  // Mengenstaffel
  quantityMin   Float?      // ab welcher Menge gilt der Preis
  quantityMax   Float?
  packagingForm PackagingForm?  // DRUM, IBC, CANISTER ...

  regionCode    String?     // ISO-2 Country: DE, CH, AT, ...

  source        PriceSource
  status        PriceStatus @default(PENDING)

  // Submission
  submittedByUserId String?
  submittedByUser   User?     @relation("SubmittedPrices", fields: [submittedByUserId], references: [id], onDelete: SetNull)
  submittedAt       DateTime  @default(now())

  // Verifizierung
  verifiedByUserId  String?
  verifiedByUser    User?     @relation("VerifiedPrices", fields: [verifiedByUserId], references: [id], onDelete: SetNull)
  verifiedAt        DateTime?
  rejectionReason   String?

  // Provenance
  sourceUrl     String?
  sourceLabel   String?
  notes         String?

  // Wenn aus Transaction abgeleitet
  transactionId String?     @unique

  createdAt     DateTime    @default(now())

  @@index([productId])
  @@index([observedAt])
  @@index([status])
  @@index([source])
  @@index([productId, status, observedAt])
}

model Rfq {
  id              String         @id @default(cuid())
  buyerId         String
  buyer           User           @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  status          RfqStatus      @default(OPEN)
  visibility      RfqVisibility  @default(PUBLIC)

  productType     String
  manufacturer    String?
  isoViscosity    String?
  chemistry       ChemistryBase?
  applicationArea String?

  quantity        Float
  quantityUnit    String         @default("L")
  locationRegion  String

  deadline        DateTime
  budgetMinEur    Float?
  budgetMaxEur    Float?
  notes           String?

  // Anforderungen / Pain Points
  requiredCertifications String[]  @default([])
  avoidIssues            String[]  @default([])
  workpieceMaterial      String?

  acceptedOfferId String?        @unique

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  offers          RfqOffer[]
  transaction     Transaction?

  @@index([status])
  @@index([productType])
  @@index([locationRegion])
}

model RfqOffer {
  id                  String          @id @default(cuid())
  rfqId               String
  rfq                 Rfq             @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  sellerId            String
  seller              User            @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  priceEur            Float
  quantity            Float
  quantityUnit        String          @default("L")
  deliveryDays        Int
  notes               String?
  alternativeProduct  String?
  alternativeReason   String?

  status              RfqOfferStatus  @default(PENDING)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@unique([rfqId, sellerId])
  @@index([rfqId])
  @@index([sellerId])
}

model Conversation {
  id        String   @id @default(cuid())
  buyerId   String
  sellerId  String
  listingId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buyer    User      @relation("BuyerThreads", fields: [buyerId], references: [id], onDelete: Cascade)
  seller   User      @relation("SellerThreads", fields: [sellerId], references: [id], onDelete: Cascade)
  listing  Listing?  @relation(fields: [listingId], references: [id], onDelete: SetNull)
  messages Message[]

  @@unique([buyerId, sellerId, listingId])
  @@index([buyerId])
  @@index([sellerId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  createdAt      DateTime     @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model Listing {
  id              String         @id @default(cuid())
  sellerId        String
  seller          User           @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  status          ListingStatus  @default(ACTIVE)

  // FDS 4.2 Datenmodell
  productType     String         // Hydrauliköl, KSS-Emulsion, etc.
  manufacturer    String         // Shell, Fuchs, Mobil, OEM-Eigenmarke — Freitext, deprecated zugunsten manufacturerId
  manufacturerId  String?
  manufacturerRef Manufacturer?  @relation(fields: [manufacturerId], references: [id], onDelete: SetNull)
  productName     String         // z.B. Tellus S2 M 46
  isoViscosity    String?        // ISO VG 32, 46, 68, ...
  chemistry       ChemistryBase  @default(MINERAL)
  applicationArea String         // CNC, Schleifen, Hydraulik, ...

  quantity        Float          // Verfügbare Menge
  quantityUnit    String         @default("L") // L, kg, drums, IBCs
  minOrderQty     Float?

  locationRegion  String         // Region/Land — keine Adresse
  packaging       PackagingForm  @default(DRUM)

  productionDate  DateTime?
  expiryDate      DateTime?

  certificates    String[]       // OEM-Freigaben, ISO, DIN, TRGS 611
  priceEur        Float?         // optional, "auf Anfrage" wenn null
  shippingTerms   String?        // Selbstabholung / Lieferung / verhandelbar

  description     String?

  // Fertigungs-Eignung — Bearbeitungsverfahren
  machiningOperations String[] @default([])

  // Rezeptur-Info
  mineralOilContent   Float?   // 0-100 %
  containsGlycol      Boolean?

  // Automatisierungs-Eignung (1-5) und vom Hersteller empfohlene Messverfahren
  automationSuitability Int?
  measurementMethods    String[] @default([])

  sdsId           String?
  sds             SafetyDataSheet? @relation(fields: [sdsId], references: [id], onDelete: SetNull)

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  conversations   Conversation[]
  transactions    Transaction[]

  @@index([productType])
  @@index([manufacturer])
  @@index([manufacturerId])
  @@index([isoViscosity])
  @@index([status])
  @@index([sdsId])
}

model Transaction {
  id            String            @id @default(cuid())
  buyerId       String
  sellerId      String
  rfqId         String?           @unique
  listingId     String?

  totalEur      Float
  quantity      Float
  quantityUnit  String            @default("L")

  status        TransactionStatus @default(PENDING)
  shippedAt     DateTime?
  completedAt   DateTime?
  canceledAt    DateTime?

  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  buyer    User     @relation("BuyerTx", fields: [buyerId], references: [id], onDelete: Cascade)
  seller   User     @relation("SellerTx", fields: [sellerId], references: [id], onDelete: Cascade)
  rfq      Rfq?     @relation(fields: [rfqId], references: [id], onDelete: SetNull)
  listing  Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)
  reviews  Review[]

  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
}

model Review {
  id            String      @id @default(cuid())
  transactionId String
  reviewerId    String
  revieweeId    String
  rating        Int         // 1–5
  comment       String?
  tags          ReviewTag[]
  createdAt     DateTime    @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  reviewer    User        @relation("ReviewsGiven", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewee    User        @relation("ReviewsReceived", fields: [revieweeId], references: [id], onDelete: Cascade)

  @@unique([transactionId, reviewerId])
  @@index([revieweeId])
}

model SafetyDataSheet {
  id            String       @id @default(cuid())
  manufacturer  String       // Freitext, deprecated zugunsten manufacturerId
  manufacturerId String?
  manufacturerRef Manufacturer? @relation(fields: [manufacturerId], references: [id], onDelete: SetNull)
  productName   String
  category      SdsCategory
  language      SdsLanguage  @default(DE)
  version       String?
  revisionDate  DateTime?

  sourceUrl     String
  filePath      String
  fileSizeBytes Int
  sha256        String       @unique
  pageCount     Int?

  extractedText String?

  // Normalisierter Suchindex: productName + manufacturer + version, lowercase,
  // ohne Bindestriche/Spaces/Punkte/Schrägstriche. Erlaubt "bcool755" → "B-Cool 755".
  // Wird beim Seed (lib/normalize-search.ts) und Backfill gesetzt.
  searchTokens  String?

  // -------------------------------------------------------------------------
  // Aus extractedText geparste strukturierte Felder (siehe lib/sds-parser.ts)
  // -------------------------------------------------------------------------
  // GHS / CLP
  hStatements      String[]  @default([])  // z.B. "H226", "H315", "H319"
  pStatements      String[]  @default([])  // z.B. "P210", "P280", "P305+P351+P338"
  ghsPictograms    String[]  @default([])  // z.B. "GHS02", "GHS07", "GHS09"
  signalWord       String?                  // "Gefahr" / "Achtung" / "Danger" / "Warning"

  // Physikochemische Kennzahlen (Section 9)
  physicalState    String?                  // "flüssig", "fest", "Aerosol"
  appearanceColor  String?                  // "klar", "gelblich", "transparent"
  odor             String?                  // "öltypisch", "schwach", "geruchlos"
  phValue          Float?                   // pH (Konzentrat oder Emulsion)
  phContext        String?                  // "Konzentrat", "5% Emulsion"
  flashpointC      Float?                   // °C
  densityGcm3      Float?                   // g/cm³ bei 20°C
  viscosityKv40    Float?                   // mm²/s bei 40°C
  pourpointC       Float?                   // Stockpunkt °C
  boilingPointC    Float?                   // Siedepunkt °C
  waterSolubility  String?                  // "löslich", "nicht löslich", "emulgierbar"

  // Inhaltsstoffe (Section 3)
  casNumbers       String[]  @default([])  // alle erkannten CAS-Nummern im Text

  // -------------------------------------------------------------------------
  // REACH + Inhaltsstoff-Flags (Parser-Heuristik, siehe lib/sds-ingredients.ts)
  // -------------------------------------------------------------------------
  // REACH-Konformität: null = unbekannt, true = registriert/konform, false = nicht
  reachCompliant            Boolean?
  reachNotes                String?         // Freitext, z.B. "Annex XVII", "SVHC: keine"
  svhcSubstances            String[]  @default([])  // erkannte SVHC-Stoffe (Name+CAS)

  // Inhaltsstoff-Klassen (true = enthalten laut SDS, false = ausdrücklich frei, null = unklar)
  containsBoron             Boolean?    // Borsäure, Borate, Borax (CAS 10043-35-3 u.a.)
  containsFormaldehydeReleaser Boolean? // Bronopol, DMDM-Hydantoin, Triazin etc.
  containsSecondaryAmines   Boolean?    // DEA, Morpholin, Diethylamin (Nitrosamin-Risiko)
  containsChlorinatedParaffins Boolean? // SCCP, MCCP — REACH Anhang XVII
  containsMineralOil        Boolean?    // Mineralöl als Hauptkomponente
  containsPrimaryAromaticAmines Boolean? // PAA — REACH-relevant

  // Wirkstoffe / Biozide
  hasBactericide            Boolean?    // MIT, BIT, CMIT, OIT, Formaldehyd-Donatoren
  hasFungicide              Boolean?    // IPBC, Pyrithion-Natrium etc.
  biocidalActives           String[]  @default([])  // konkrete Wirkstoffe als Strings

  // Transport (Section 14)
  adrClass         String?                  // "9", "3", "kein Gefahrgut"
  unNumber         String?                  // "UN 1993" etc.
  transportClass   String?                  // verbatim Bezeichnung

  // Hersteller-/Lieferant-Info (Section 1)
  supplierName     String?
  supplierAddress  String?
  emergencyPhone   String?

  // Parser-Metadaten
  parsedAt         DateTime?
  parsedVersion    String?                  // welche Parser-Version lief

  fetchedAt     DateTime     @default(now())

  listings      Listing[]
  products      Product[]

  @@index([manufacturer])
  @@index([manufacturerId])
  @@index([category])
  @@index([productName])
  @@index([searchTokens])
}

// === Praxis-Probleme aus Foren, Hersteller-Hinweisen, Distributoren, Reviews ===
enum IssueCategory {
  BIOLOGY           // Bakterien, Pilze, Verkeimung, Geruch
  FOAM              // Schaumbildung
  CORROSION         // Korrosion an Werkstücken, Maschinen, Tank
  TOOL_WEAR         // Werkzeugverschleiß, kürzere Standzeiten
  OPERATOR_HEALTH   // Hautirritation, Atemwege, Allergien, MAK
  SEAL_DAMAGE       // Dichtungen, Schläuche, Lackangriff
  WORKPIECE_STAINS  // Fleckenbildung Buntmetall, Alu-Anlauffarben, Niro
  RESIDUES          // Klebrige Rückstände, Harzbildung, Maschinenverschmutzung
  FILTRATION        // Filtrierbarkeit, Tramp-Oil-Aufnahme
  STABILITY         // Emulsionsstabilität, Frostempfindlichkeit, Lagerung
  PERFORMANCE       // Kühlleistung, Schmierleistung, Spülwirkung unzureichend
  COMPATIBILITY     // Mischbarkeit mit anderem Öl/MMS/HD-Konzentrat
  REGULATORY        // REACH, TRGS 611, Biozid-VO, Borfrei-Konflikte
  SHELF_LIFE        // Kurze Lager-/Standzeit im Tank
  OTHER
}

enum IssueSeverity {
  LOW      // Hinweis/kosmetisch
  MEDIUM   // Beeinträchtigt Prozess, aber lösbar
  HIGH     // Ausfall, Maschinenschaden, Gesundheitsrisiko
}

enum IssueSourceType {
  FORUM             // industryarena, praktiker.com, cnczone, reddit r/Machinists, fachforum
  MANUFACTURER      // Hersteller-FAQ, Anwendungstipps, Servicedokument
  DISTRIBUTOR       // Distributor-Warnung, Anwendungshinweis
  CASE_STUDY        // dokumentierte Fallstudie (Verein, Hochschule)
  REVIEW            // User-Review (Amazon, Trustpilot)
  REGULATORY        // BAuA, ECHA, TRGS-Updates
  SDS               // direkt aus Sicherheitsdatenblatt entnommen
  USER_REPORT       // direkt vom Plattform-User gemeldet
  OTHER
}

enum IssueStatus {
  PENDING    // gemeldet, nicht verifiziert
  VERIFIED   // von Admin/TRADE_ASSURED bestätigt
  RESOLVED   // Hersteller hat in neuerer Formulierung behoben
  REJECTED   // unzutreffend / nicht reproduzierbar
}

model ProductIssue {
  id              String          @id @default(cuid())

  productId       String
  product         Product         @relation(fields: [productId], references: [id], onDelete: Cascade)

  category        IssueCategory
  severity        IssueSeverity   @default(MEDIUM)
  status          IssueStatus     @default(PENDING)

  title           String          // Kurzbeschreibung, z.B. "Schaumbildung bei niedriger Konzentration"
  description     String          // Ausführlicher Bericht

  symptoms        String[]        @default([])  // ["pH-Drop", "Geruch", "Fleckenbildung Messing"]
  rootCause       String?         // wenn bekannt: "Bakterien (Pseudomonas) bei Stillstand"
  workaround      String?         // Tipps zur Behebung
  preventiveMeasure String?       // wie vermeiden

  // Kontext
  affectedMaterials   String[]   @default([])  // Materialien wo Problem auftritt
  affectedOperations  String[]   @default([])  // Anwendungen wo Problem auftritt
  reportedConcentration Float?   // bei wassermischbaren KSS, %
  reportedPh            Float?
  reportedWaterHardness Int?     // °dH

  sourceType      IssueSourceType
  sourceUrl       String?         // URL des Forenposts / Doks
  sourceTitle     String?         // Titel des Posts / Artikels
  sourceAuthor    String?         // wenn bekannt
  sourceDate      DateTime?       // wann der Bericht erstellt wurde

  language        SdsLanguage     @default(DE)

  // Verifizierung
  submittedByUserId String?
  submittedByUser   User?         @relation("ProductIssueSubmitted", fields: [submittedByUserId], references: [id], onDelete: SetNull)
  verifiedByUserId  String?
  verifiedByUser    User?         @relation("ProductIssueVerified", fields: [verifiedByUserId], references: [id], onDelete: SetNull)
  verifiedAt        DateTime?

  // Trust-Indikatoren
  isOfficial       Boolean        @default(false)  // Hersteller-Doku
  reportCount      Int            @default(1)      // wie oft gemeldet (similar issues merged)

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([productId])
  @@index([category])
  @@index([severity])
  @@index([status])
  @@index([sourceType])
}

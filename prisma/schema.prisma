generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  RESELLER
  OEM
  ADMIN
}

enum UserTrustTier {
  UNVERIFIED
  VERIFIED
  TRADE_ASSURED
  PREMIUM
  DIAMOND
}

enum ListingStatus {
  ACTIVE
  PAUSED
  SOLD
  ARCHIVED
}

enum RfqStatus {
  OPEN
  ACCEPTED
  EXPIRED
  CANCELED
}

enum RfqVisibility {
  PUBLIC
  VERIFIED_ONLY
}

enum RfqOfferStatus {
  PENDING
  ACCEPTED
  DECLINED
  WITHDRAWN
}

enum TransactionStatus {
  PENDING
  SHIPPED
  COMPLETED
  CANCELED
  DISPUTED
}

enum ReviewTag {
  FAST_RESPONSE
  QUALITY_AS_DESCRIBED
  ON_TIME_DELIVERY
  FAIR_NEGOTIATION
}

enum ChemistryBase {
  MINERAL
  SYNTHETIC
  SEMI_SYNTHETIC
  ESTER
  PAG
  OTHER
}

enum PackagingForm {
  DRUM
  IBC
  TANK
  CANISTER
  BULK
  OTHER
}

enum SdsCategory {
  WATER_MISCIBLE_COOLANT
  NEAT_CUTTING_OIL
  HYDRAULIC_OIL
  GEAR_OIL
  MOTOR_OIL
  GREASE
  OTHER
}

enum SdsLanguage {
  DE
  EN
  FR
  IT
  OTHER
}

enum ProductCategory {
  COOLANT_WATER_MIX     // wassermischbarer KSS-Konzentrat
  COOLANT_NEAT          // nicht wassermischbares Schneidöl
  GRINDING_OIL          // Schleiföl
  EDM_FLUID             // Erodieröl (Senk/Draht), Dielektrikum
  HYDRAULIC_OIL
  GEAR_OIL
  COMPRESSOR_OIL
  SLIDEWAY_OIL          // Bettbahnöl
  FORMING_OIL           // Stanz-/Umform-/Tiefziehöl
  CLEANER               // Reiniger / Entfetter
  CORROSION_PROTECTION
  GREASE
  SPECIALTY             // Spezial-/Sonderschmierstoff
  ADDITIVE
  OTHER
}

enum MaterialCompatibility {
  RECOMMENDED   // explizit für diesen Werkstoff empfohlen
  COMPATIBLE    // unproblematisch
  CAUTION       // mit Einschränkungen / Bedingungen
  UNSUITABLE    // nicht geeignet, dokumentierte Probleme
}

enum BusinessFocus {
  COOLANT              // Kühlschmierstoffe (wassermischbar)
  NEAT_OIL             // Nicht wassermischbare Schneidöle
  LUBRICANT            // Schmierstoffe allgemein (Hydraulik, Getriebe, Motor)
  GREASE               // Schmierfette
  CLEANER              // Reiniger / Entfetter
  CORROSION_PROTECTION // Korrosionsschutz
  CHEMICAL_SUPPLIER    // Chemie-Distributor / Mineralöl-Handel
  ADDITIVE             // Additiv-Hersteller
}

model Manufacturer {
  id        String   @id @default(cuid())
  name      String   @unique   // Display name, z.B. "Blaser Swisslube"
  slug      String   @unique   // url-safe, z.B. "blaser-swisslube"

  logoPath  String?            // /brand-logos/BlaserSwisslubeLogo.png
  website   String?            // https://www.blaser.com

  headquartersCountry String?  // ISO-3166-1 alpha-2 oder Klartext
  headquartersCity    String?
  foundedYear         Int?

  businessFocus   BusinessFocus[] @default([])
  productFamilies String[]        @default([])  // z.B. ["Blasocut", "Vasco", "Synergy"]
  description     String?

  // Wissens-Metadaten — was wir aus dem Web/Datenblättern wissen
  knownForApplications String[] @default([])    // z.B. ["Schleifen", "Drehen Alu", "Tiefbohren"]
  notes               String?                    // freitext, manuell pflegbar

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listings  Listing[]
  sds       SafetyDataSheet[]
  products  Product[]

  @@index([slug])
}

model Product {
  id              String       @id @default(cuid())
  manufacturerId  String
  manufacturer    Manufacturer @relation(fields: [manufacturerId], references: [id], onDelete: Cascade)

  name            String       // Vollständiger Name z.B. "Blasocut 2000 CF"
  slug            String       // url-safe, eindeutig pro Hersteller
  productFamily   String?      // z.B. "Blasocut"
  category        ProductCategory
  chemistry       ChemistryBase?

  description     String?

  // Anwendung
  applicationAreas    String[] @default([])  // Drehen, Fräsen, Schleifen, Stanzen, ...
  suitableMaterials   String[] @default([])  // Stahl, Alu, Buntmetall, Guss, Titan, Hartmetall
  unsuitableMaterials String[] @default([])  // Werkstoffe wo Probleme dokumentiert sind

  // Refraktometer — Schlüsselwert für KSS-Konzentratbestimmung
  refractometerFactor Float?    // Brix × Faktor = % Konzentration

  // Empfohlene Konzentration im Gebrauchsbereich (wassermischbare KSS)
  recommendedConcentrationMin Float?  // % v/v
  recommendedConcentrationMax Float?  // % v/v

  // pH
  phConcentrate Float?
  phEmulsionMin Float?           // bei Soll-Konzentration
  phEmulsionMax Float?

  // Physik
  densityGcm3   Float?           // bei 20 °C
  flashpointC   Int?              // °C (nur für Öle)
  viscosityIso  String?           // ISO VG (für Öle)
  viscosityKv40 Float?            // mm²/s bei 40 °C
  viscosityKv100 Float?           // mm²/s bei 100 °C

  // Ansetzwasser-Anforderungen (wassermischbare KSS)
  waterHardnessMinDh  Int?       // °dH min empfohlen
  waterHardnessMaxDh  Int?       // °dH max empfohlen
  waterHardnessNotes  String?    // z.B. "demineralisiertes Wasser ungeeignet"

  // Lebensmittel-/Norm-Freigaben
  certifications  String[]  @default([])  // FDA H1, DIN 51385, TRGS 611, OEM-Freigaben

  // Markierungen
  containsBor              Boolean?
  containsFormaldehydeDepot Boolean?
  containsMineralOil       Boolean?
  containsChlorine         Boolean?
  mineralOilContentPct     Float?       // 0-100 %

  // Quellen
  sourceUrl       String?       // Produktseite Hersteller
  dataSheetUrl    String?       // technisches Datenblatt (PDS)
  sdsUrl          String?       // Sicherheitsdatenblatt
  sourceConfidence String?      // "verifiziert", "modelliert", "geschätzt"

  notes           String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  compatibilityNotes MaterialCompatibilityNote[]

  @@unique([manufacturerId, slug])
  @@index([manufacturerId])
  @@index([category])
  @@index([productFamily])
}

model ComparisonAnalysis {
  id           String   @id @default(cuid())
  // sha256 über die sortierte Liste der verglichenen IDs (Listings oder Products)
  cacheKey     String   @unique
  scope        String   // "listings" oder "products"
  ids          String[] // die verglichenen IDs (sortiert wie cacheKey berechnet)
  // Strukturiertes Ergebnis als JSON: { perItem: [...], recommendation: "...", model: "..." }
  result       Json
  source       String   // "anthropic-claude" | "heuristic-fallback"
  createdAt    DateTime @default(now())

  @@index([scope, createdAt])
}

model MaterialCompatibilityNote {
  id          String                @id @default(cuid())
  productId   String?
  product     Product?              @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Bei productId = null: allgemeine Regel (z.B. "Buntmetall + pH > 9.5 → Verfärbung")
  // Bei productId gesetzt: produkt-spezifischer Hinweis
  scope       String                // "product" oder "general"

  material    String                // "Aluminium", "Buntmetall", "Magnesium", "Grauguss", "Titan", "Stahl", "Edelstahl"
  compatibility MaterialCompatibility

  condition   String?               // z.B. "pH > 9.5", "Konzentration > 8%", "demineralisiertes Wasser"
  note        String                // Erklärung was passiert / worauf zu achten

  sourceUrl   String?               // Hersteller-Doku, Fachartikel, FAQ
  sourceLabel String?               // z.B. "Blaser FAQ", "VSI-Merkblatt"

  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([productId])
  @@index([material])
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String
  pseudonym    String        @unique
  role         UserRole      @default(RESELLER)
  trustTier    UserTrustTier @default(UNVERIFIED)
  // KYC light — internal only
  companyName  String?
  vatId        String?
  country      String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  listings        Listing[]
  buyerThreads    Conversation[] @relation("BuyerThreads")
  sellerThreads   Conversation[] @relation("SellerThreads")
  messages        Message[]
  rfqs            Rfq[]
  offers          RfqOffer[]
  buyerTxns       Transaction[] @relation("BuyerTx")
  sellerTxns      Transaction[] @relation("SellerTx")
  reviewsGiven    Review[]      @relation("ReviewsGiven")
  reviewsReceived Review[]      @relation("ReviewsReceived")
}

model Rfq {
  id              String         @id @default(cuid())
  buyerId         String
  buyer           User           @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  status          RfqStatus      @default(OPEN)
  visibility      RfqVisibility  @default(PUBLIC)

  productType     String
  manufacturer    String?
  isoViscosity    String?
  chemistry       ChemistryBase?
  applicationArea String?

  quantity        Float
  quantityUnit    String         @default("L")
  locationRegion  String

  deadline        DateTime
  budgetMinEur    Float?
  budgetMaxEur    Float?
  notes           String?

  // Anforderungen / Pain Points
  requiredCertifications String[]  @default([])
  avoidIssues            String[]  @default([])
  workpieceMaterial      String?

  acceptedOfferId String?        @unique

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  offers          RfqOffer[]
  transaction     Transaction?

  @@index([status])
  @@index([productType])
  @@index([locationRegion])
}

model RfqOffer {
  id                  String          @id @default(cuid())
  rfqId               String
  rfq                 Rfq             @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  sellerId            String
  seller              User            @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  priceEur            Float
  quantity            Float
  quantityUnit        String          @default("L")
  deliveryDays        Int
  notes               String?
  alternativeProduct  String?
  alternativeReason   String?

  status              RfqOfferStatus  @default(PENDING)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@unique([rfqId, sellerId])
  @@index([rfqId])
  @@index([sellerId])
}

model Conversation {
  id        String   @id @default(cuid())
  buyerId   String
  sellerId  String
  listingId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buyer    User      @relation("BuyerThreads", fields: [buyerId], references: [id], onDelete: Cascade)
  seller   User      @relation("SellerThreads", fields: [sellerId], references: [id], onDelete: Cascade)
  listing  Listing?  @relation(fields: [listingId], references: [id], onDelete: SetNull)
  messages Message[]

  @@unique([buyerId, sellerId, listingId])
  @@index([buyerId])
  @@index([sellerId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  createdAt      DateTime     @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model Listing {
  id              String         @id @default(cuid())
  sellerId        String
  seller          User           @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  status          ListingStatus  @default(ACTIVE)

  // FDS 4.2 Datenmodell
  productType     String         // Hydrauliköl, KSS-Emulsion, etc.
  manufacturer    String         // Shell, Fuchs, Mobil, OEM-Eigenmarke — Freitext, deprecated zugunsten manufacturerId
  manufacturerId  String?
  manufacturerRef Manufacturer?  @relation(fields: [manufacturerId], references: [id], onDelete: SetNull)
  productName     String         // z.B. Tellus S2 M 46
  isoViscosity    String?        // ISO VG 32, 46, 68, ...
  chemistry       ChemistryBase  @default(MINERAL)
  applicationArea String         // CNC, Schleifen, Hydraulik, ...

  quantity        Float          // Verfügbare Menge
  quantityUnit    String         @default("L") // L, kg, drums, IBCs
  minOrderQty     Float?

  locationRegion  String         // Region/Land — keine Adresse
  packaging       PackagingForm  @default(DRUM)

  productionDate  DateTime?
  expiryDate      DateTime?

  certificates    String[]       // OEM-Freigaben, ISO, DIN, TRGS 611
  priceEur        Float?         // optional, "auf Anfrage" wenn null
  shippingTerms   String?        // Selbstabholung / Lieferung / verhandelbar

  description     String?

  // Fertigungs-Eignung — Bearbeitungsverfahren
  machiningOperations String[] @default([])

  // Rezeptur-Info
  mineralOilContent   Float?   // 0-100 %
  containsGlycol      Boolean?

  // Automatisierungs-Eignung (1-5) und vom Hersteller empfohlene Messverfahren
  automationSuitability Int?
  measurementMethods    String[] @default([])

  sdsId           String?
  sds             SafetyDataSheet? @relation(fields: [sdsId], references: [id], onDelete: SetNull)

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  conversations   Conversation[]
  transactions    Transaction[]

  @@index([productType])
  @@index([manufacturer])
  @@index([manufacturerId])
  @@index([isoViscosity])
  @@index([status])
  @@index([sdsId])
}

model Transaction {
  id            String            @id @default(cuid())
  buyerId       String
  sellerId      String
  rfqId         String?           @unique
  listingId     String?

  totalEur      Float
  quantity      Float
  quantityUnit  String            @default("L")

  status        TransactionStatus @default(PENDING)
  shippedAt     DateTime?
  completedAt   DateTime?
  canceledAt    DateTime?

  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  buyer    User     @relation("BuyerTx", fields: [buyerId], references: [id], onDelete: Cascade)
  seller   User     @relation("SellerTx", fields: [sellerId], references: [id], onDelete: Cascade)
  rfq      Rfq?     @relation(fields: [rfqId], references: [id], onDelete: SetNull)
  listing  Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)
  reviews  Review[]

  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
}

model Review {
  id            String      @id @default(cuid())
  transactionId String
  reviewerId    String
  revieweeId    String
  rating        Int         // 1–5
  comment       String?
  tags          ReviewTag[]
  createdAt     DateTime    @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  reviewer    User        @relation("ReviewsGiven", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewee    User        @relation("ReviewsReceived", fields: [revieweeId], references: [id], onDelete: Cascade)

  @@unique([transactionId, reviewerId])
  @@index([revieweeId])
}

model SafetyDataSheet {
  id            String       @id @default(cuid())
  manufacturer  String       // Freitext, deprecated zugunsten manufacturerId
  manufacturerId String?
  manufacturerRef Manufacturer? @relation(fields: [manufacturerId], references: [id], onDelete: SetNull)
  productName   String
  category      SdsCategory
  language      SdsLanguage  @default(DE)
  version       String?
  revisionDate  DateTime?

  sourceUrl     String
  filePath      String
  fileSizeBytes Int
  sha256        String       @unique
  pageCount     Int?

  extractedText String?

  // -------------------------------------------------------------------------
  // Aus extractedText geparste strukturierte Felder (siehe lib/sds-parser.ts)
  // -------------------------------------------------------------------------
  // GHS / CLP
  hStatements      String[]  @default([])  // z.B. "H226", "H315", "H319"
  pStatements      String[]  @default([])  // z.B. "P210", "P280", "P305+P351+P338"
  ghsPictograms    String[]  @default([])  // z.B. "GHS02", "GHS07", "GHS09"
  signalWord       String?                  // "Gefahr" / "Achtung" / "Danger" / "Warning"

  // Physikochemische Kennzahlen (Section 9)
  physicalState    String?                  // "flüssig", "fest", "Aerosol"
  appearanceColor  String?                  // "klar", "gelblich", "transparent"
  odor             String?                  // "öltypisch", "schwach", "geruchlos"
  phValue          Float?                   // pH (Konzentrat oder Emulsion)
  phContext        String?                  // "Konzentrat", "5% Emulsion"
  flashpointC      Float?                   // °C
  densityGcm3      Float?                   // g/cm³ bei 20°C
  viscosityKv40    Float?                   // mm²/s bei 40°C
  pourpointC       Float?                   // Stockpunkt °C
  boilingPointC    Float?                   // Siedepunkt °C
  waterSolubility  String?                  // "löslich", "nicht löslich", "emulgierbar"

  // Inhaltsstoffe (Section 3)
  casNumbers       String[]  @default([])  // alle erkannten CAS-Nummern im Text

  // Transport (Section 14)
  adrClass         String?                  // "9", "3", "kein Gefahrgut"
  unNumber         String?                  // "UN 1993" etc.
  transportClass   String?                  // verbatim Bezeichnung

  // Hersteller-/Lieferant-Info (Section 1)
  supplierName     String?
  supplierAddress  String?
  emergencyPhone   String?

  // Parser-Metadaten
  parsedAt         DateTime?
  parsedVersion    String?                  // welche Parser-Version lief

  fetchedAt     DateTime     @default(now())

  listings      Listing[]

  @@index([manufacturer])
  @@index([manufacturerId])
  @@index([category])
  @@index([productName])
}
